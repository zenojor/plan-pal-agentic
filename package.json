{
  "name": "plan-pal-agentic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:new",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "build:web": "npm --prefix apps/web run build",
    "build:api": "npm --prefix apps/api run build",
    "build:domain": "npm --prefix packages/domain run build",
    "build:eval": "npm --prefix packages/eval run build",
    "build:agent": "npm --prefix packages/agent run build",
    "build:db": "npm --prefix packages/db run build",
    "build:new": "npm run build:domain && npm run build:db && npm run build:agent && npm run build:eval && npm run build:api && npm run build:web",
    "eval:agent": "pnpm --dir packages/eval eval:agent",
    "test:new": "pnpm --dir packages/domain test && pnpm --dir packages/db test && pnpm --dir packages/agent test && pnpm --dir apps/api test && pnpm --dir apps/web test"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "vitest": "^4.0.15"
  }
}

